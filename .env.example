# ──────────────────────────────────────────────
# SAM.SOTTA 블로그 생성기 환경변수 설정
# 이 파일을 복사하여 .env 파일로 만들고 값을 채워주세요
# cp .env.example .env
# ──────────────────────────────────────────────

# Gemini API Key (Google AI Studio에서 발급)
GEMINI_API_KEY=AIzaSyDghYdHRPKM3NAJbTcLiWdRCReps1S6hsk

# Google OAuth2 (Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth Refresh Token
# 최초 1회 /api/auth/google/url 접속 후 인증하면 서버 콘솔에 출력됩니다.
# 출력된 값을 여기에 복사하세요.
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Google Docs 문서 ID
# URL: https://docs.google.com/document/d/{DOCUMENT_ID}/edit
GOOGLE_DOC_ID=19d5e01j5IYakOKftv-7Y28T8oo0SStGKRwGej1QK6Wk

# 앱 배포 URL (로컬 개발 시 기본값 사용)
APP_URL=http://localhost:3000
